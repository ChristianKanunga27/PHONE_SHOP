# MongoDB Atlas Connection String
# Replace the placeholder below with your actual MongoDB Atlas connection string
# Format: mongodb+srv://<username>:<password>@<cluster-url>/<database-name>?options
MONGO_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/phone_shop?retryWrites=true&w=majority

# Session Secret
SESSION_SECRET=your_session_secret_here

# Server Port (optional - defaults to 3000)
PORT=3000
